# ── Backend Environment Variables (Render) ──
# PostgreSQL connection string (Render provides this when you create a database)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rebook

# JSON Web Token secret – use a long random string in production
JWT_SECRET=rebook-dev-secret-change-in-production

# Port (Render sets this automatically)
PORT=5000

# Frontend URL(s) for CORS – comma-separated for multiple origins
# Local:      http://localhost:8080
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:8080

# Public URL of this backend (used for uploaded image URLs)
# Local:      http://localhost:5000
# Production: https://your-app.onrender.com
BACKEND_URL=http://localhost:5000

# Cloudinary (persistent image storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Set to "production" on Render
NODE_ENV=development
